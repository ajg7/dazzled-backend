# Normalize line endings: store as LF, check out native
* text=auto

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF for Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Language diffs
*.cs text diff=csharp

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary
*.snk binary
*.pfx binary
